# ============================================
# WWTRAIL - Variables de Produccion (DigitalOcean)
# ============================================
# Copia este archivo como .env y rellena los valores reales
# cp .env.production.example .env

# --- Base de Datos ---
POSTGRES_USER=wwtrail
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
POSTGRES_DB=wwtrail_db

# --- Redis ---
REDIS_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
REDIS_TTL=3600

# --- JWT (generar secrets aleatorios) ---
# Puedes generar con: openssl rand -base64 64
JWT_SECRET=CAMBIAR_POR_SECRET_SEGURO
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CAMBIAR_POR_REFRESH_SECRET_SEGURO
JWT_REFRESH_EXPIRES_IN=30d

# --- CORS ---
# Cambiar por tu dominio real
CORS_ORIGIN=https://wwtrail.com

# --- Frontend (se inyectan en build time) ---
# IMPORTANTE: debe apuntar a tu dominio publico + /api
NEXT_PUBLIC_API_URL=https://wwtrail.com/api
NEXT_PUBLIC_APP_NAME=WWTRAIL
NEXT_PUBLIC_DEFAULT_LANGUAGE=es

# --- Subida de Archivos ---
MAX_FILE_SIZE=10485760
# No cambiar UPLOAD_PATH, esta configurado internamente en el container

# --- AI Translation (opcional) ---
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AUTO_TRANSLATE_ENABLED=true
AUTO_TRANSLATE_LANGUAGES=EN,IT,CA,FR,DE
DEFAULT_LANGUAGE=ES
AUTO_TRANSLATE_OVERWRITE=false
AUTO_TRANSLATE_BACKGROUND=true
AUTO_TRANSLATE_ONLY_PUBLISHED=true

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Email SMTP (opcional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@wwtrail.com

# --- Logging ---
LOG_LEVEL=info
