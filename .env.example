# ============================================
# WWTRAIL - Production Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# ---- Database ----
POSTGRES_USER=wwtrail
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=wwtrail_db

# ---- JWT ----
JWT_SECRET=CHANGE_ME_random_secret_key
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_another_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME_redis_password

# ---- CORS ----
CORS_ORIGIN=https://wwtrail.com

# ---- Frontend URLs ----
NEXT_PUBLIC_API_URL=https://api.wwtrail.com/api
NEXT_PUBLIC_APP_NAME=WWTRAIL
NEXT_PUBLIC_DEFAULT_LANGUAGE=es

# ---- SSL / Let's Encrypt ----
LETSENCRYPT_EMAIL=admin@wwtrail.com

# ---- AI Translation ----
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Auto Translation (optional) ----
AUTO_TRANSLATE_ENABLED=false
AUTO_TRANSLATE_BACKGROUND=true
AUTO_TRANSLATE_LANGUAGES=en,fr,de
AUTO_TRANSLATE_ONLY_PUBLISHED=true
AUTO_TRANSLATE_OVERWRITE=false
DEFAULT_LANGUAGE=es

# ---- Storage (DigitalOcean Spaces) ----
# STORAGE_TYPE: 'spaces' to use DO Spaces, otherwise falls back to local /public/uploads
STORAGE_TYPE=spaces
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=wwtrail-uploads
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
DO_SPACES_CDN=https://wwtrail-uploads.fra1.cdn.digitaloceanspaces.com
NEXT_PUBLIC_SPACES_URL=https://wwtrail-uploads.fra1.cdn.digitaloceanspaces.com

# ---- App URLs ----
# NEXT_PUBLIC_APP_URL is used server-side to call same-origin API routes
NEXT_PUBLIC_APP_URL=https://wwtrail.com
FRONTEND_URL=https://wwtrail.com

# ---- Initial Setup ----
# Dedicated secret required to create the first ADMIN via POST /api/setup.
# MUST be different from JWT_SECRET. Leave unset to disable the setup endpoint.
SETUP_SECRET=

# ---- Email ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@wwtrail.com

# ---- External APIs ----
MAPBOX_TOKEN=
OPENWEATHER_API_KEY=

# ---- Logging ----
LOG_LEVEL=info
