# Database
DATABASE_URL=postgresql://wwtrail:wwtrail_password@localhost:5432/wwtrail_db?schema=public

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-change-this
JWT_REFRESH_EXPIRES_IN=30d

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=WWTRAIL
NODE_ENV=development

# File Storage (DigitalOcean Spaces or local)
STORAGE_TYPE=local
# For DigitalOcean Spaces:
# STORAGE_TYPE=spaces
# DO_SPACES_KEY=your-spaces-key
# DO_SPACES_SECRET=your-spaces-secret
# DO_SPACES_ENDPOINT=https://ams3.digitaloceanspaces.com
# DO_SPACES_BUCKET=wwtrail-uploads
# DO_SPACES_CDN=https://wwtrail-uploads.ams3.cdn.digitaloceanspaces.com

# AI Translation (OpenAI)
OPENAI_API_KEY=

# Auto Translation
AUTO_TRANSLATE_ENABLED=true
AUTO_TRANSLATE_LANGUAGES=EN,IT,CA,FR,DE
DEFAULT_LANGUAGE=ES

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@wwtrail.com

# External APIs
MAPBOX_TOKEN=
OPENWEATHER_API_KEY=

# Omniwallet / Zancadas
OMNIWALLET_SUBDOMAIN=
OMNIWALLET_API_TOKEN=
OMNIWALLET_WEBHOOK_SECRET=
